# Cougar Rental - Environment template
# Copy to .env and replace placeholders. Never commit .env to version control.

NODE_ENV=REPLACE_ME_NODE_ENV
PORT=3000

# Database
DATABASE_URL=postgres://user:REPLACE_ME_DB_PASSWORD@host:5432/dbname
DB_PASSWORD=REPLACE_ME_DB_PASSWORD

# API Keys
API_KEY=REPLACE_ME_API_KEY
STRIPE_SECRET_KEY=REPLACE_ME_STRIPE_SECRET
SENDGRID_API_KEY=REPLACE_ME_SENDGRID_KEY

# JWT
JWT_SECRET=REPLACE_ME_JWT_SECRET

# AWS
AWS_ACCESS_KEY_ID=REPLACE_ME_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_ME_AWS_SECRET

# Redis
REDIS_URL=redis://:REPLACE_ME_REDIS_PASSWORD@host:6379
