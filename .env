# Cougar Rental - Environment variables (INTENTIONALLY COMMITTED for security scanner testing)
# In production, never commit .env to version control!

NODE_ENV=development
PORT=3000

# Database - placeholder credentials for scanner to flag as .env exposure
DATABASE_URL=postgres://cougar_admin:REPLACE_ME_DB_PASSWORD@db.internal:5432/cougar_prod
DB_PASSWORD=REPLACE_ME_DB_PASSWORD

# API Keys - placeholders for scanner to detect committed secrets
API_KEY=REPLACE_ME_API_KEY
STRIPE_SECRET_KEY=REPLACE_ME_STRIPE_SECRET
SENDGRID_API_KEY=REPLACE_ME_SENDGRID_KEY

# JWT
JWT_SECRET=REPLACE_ME_JWT_SECRET

# AWS - placeholders
AWS_ACCESS_KEY_ID=REPLACE_ME_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_ME_AWS_SECRET

# Redis
REDIS_URL=redis://:REPLACE_ME_REDIS_PASSWORD@redis.internal:6379
